{
  "appId": "com.trainrhub.app",
  "appName": "TrainrHub",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "backgroundColor": "#000000",
      "showSpinner": false,
      "launchAutoHide": true
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#000000"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  },
  "ios": {
    "contentInset": "automatic",
    "preferredContentMode": "mobile"
  },
  "android": {
    "backgroundColor": "#000000"
  }
}
